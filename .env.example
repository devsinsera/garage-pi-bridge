# Sinsera Garage OBD bridge — environment configuration.
# Copy to .env and fill in.

# Supabase project (same one Sinsera Core uses)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Auth — bridge signs in with email/password to inherit the user's RLS.
# The user_id from this session is matched against garage_cars.user_id
# for the CAR_ID below.
SUPABASE_EMAIL=peta.stockdale@outlook.com
SUPABASE_PASSWORD=

# The UUID of the row in garage_cars that the bridge writes against.
# Get it via:
#   select id from garage_cars where user_id = auth.uid() and nickname ilike '%gr86%';
CAR_ID=

# OBDLink MX+ Bluetooth identity. Pair once via bluetoothctl, then
# paste the MAC here.
OBDLINK_MAC=
OBDLINK_NAME=OBDLink MX+

# Sampling cadence
SAMPLE_HZ=5
DTC_POLL_SECS=10

# How many readings to batch into one Supabase POST. Lower = lower
# latency in the web UI; higher = fewer HTTPS round trips.
BATCH_SIZE=10
